{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/**", "public/**", "admin/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/admin",
      "dest": "/server/index.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/subject/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/chapter/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server/index.js"
    }
  ]
}
